---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Dutch Cuisine Guide', url: '/cuisine/' },
];

const pageTitle = 'Dutch Cuisine Guide — Eat Your Way Across Amsterdam';
const pageDescription = 'A neighborhood-by-neighborhood guide to the dishes that define Amsterdam food culture — from bitterballen to stroopwafels to Indonesian rijsttafel. Find where to eat the real thing.';

interface Dish {
  name: string;
  image?: string;
  destination: string;
  slug: string;
  price: string;
  description: string;
  tag?: string;
}

interface MenuSection {
  region: string;
  tagline: string;
  gradient: string;
  dishes: Dish[];
}

const menu: MenuSection[] = [
  {
    region: 'Classic Dutch',
    tagline: 'Traditional Dutch comfort food — hearty, honest, and deeply satisfying. The dishes that have fueled Amsterdam for centuries.',
    gradient: 'linear-gradient(135deg, #BF360C 0%, #E8654A 100%)',
    dishes: [
      {
        name: 'Bitterballen',
        image: '/images/cuisine/bitterballen.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '6-10 EUR / $7-11 USD',
        description: 'Crispy deep-fried meatball croquettes filled with a rich beef ragout. The quintessential Dutch bar snack — order them at any brown cafe with a cold beer and sharp mustard for dipping.',
        tag: 'Iconic',
      },
      {
        name: 'Stroopwafels',
        image: '/images/cuisine/stroopwafels.jpg',
        destination: 'Albert Cuyp Market',
        slug: 'de-pijp',
        price: '2-4 EUR / $2-4 USD',
        description: 'Two thin waffle layers sandwiching warm caramel syrup. Best eaten fresh from a street vendor — hold it over your coffee to let the steam soften the caramel. Albert Cuyp Market has the best ones.',
        tag: 'Must-Try',
      },
      {
        name: 'Stamppot',
        image: '/images/cuisine/stamppot.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'jordaan',
        price: '12-18 EUR / $13-20 USD',
        description: 'Mashed potatoes mixed with vegetables (kale, sauerkraut, or endive) and served with a smoked sausage (rookworst). The ultimate Dutch winter comfort food — hearty, warming, and deeply satisfying.',
        tag: 'Heritage',
      },
      {
        name: 'Kibbeling',
        image: '/images/cuisine/kibbeling.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '5-8 EUR / $5-9 USD',
        description: 'Battered and deep-fried chunks of cod or whiting, served with remoulade or garlic sauce. Amsterdam\'s favorite street fish snack — grab a portion from any market stall or fish cart.',
        tag: 'Must-Try',
      },
      {
        name: 'Haring (Raw Herring)',
        image: '/images/cuisine/haring.jpg',
        destination: 'Centrum',
        slug: 'centrum',
        price: '4-6 EUR / $4-7 USD',
        description: 'Fresh raw herring served with diced onions and pickles. Eaten the traditional way by holding it by the tail above your head. The Hollandse Nieuwe season starts in June — visit a haringkar (herring cart) near Dam Square.',
        tag: 'Iconic',
      },
      {
        name: 'Erwtensoep (Pea Soup)',
        image: '/images/cuisine/erwtensoep.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'jordaan',
        price: '6-10 EUR / $7-11 USD',
        description: 'Thick split pea soup with smoked sausage, pork belly, celery, and leek. So thick your spoon stands up in it. A winter staple served at brown cafes across Amsterdam with rye bread and bacon.',
      },
      {
        name: 'Kroket',
        image: '/images/cuisine/kroket.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '2-4 EUR / $2-4 USD',
        description: 'A larger, elongated version of bitterballen — deep-fried ragout croquette served on a bread roll with mustard. The classic Dutch lunch. Get one from FEBO\'s famous vending-machine wall for the full Amsterdam experience.',
        tag: 'Heritage',
      },
      {
        name: 'Poffertjes',
        image: '/images/cuisine/poffertjes.jpg',
        destination: 'Albert Cuyp Market',
        slug: 'de-pijp',
        price: '4-7 EUR / $4-8 USD',
        description: 'Tiny fluffy pancakes made with buckwheat flour, served with a generous heap of powdered sugar and melted butter. Street vendors across Amsterdam serve them fresh from the griddle.',
      },
    ],
  },
  {
    region: 'Indonesian & Surinamese',
    tagline: 'Amsterdam\'s colonial history created one of Europe\'s most exciting fusion food scenes — bold spices, rich flavors, and communal dining',
    gradient: 'linear-gradient(135deg, #0D7377 0%, #4DB6AC 100%)',
    dishes: [
      {
        name: 'Rijsttafel',
        image: '/images/cuisine/rijsttafel.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '25-45 EUR / $27-49 USD',
        description: 'A spectacular Indonesian feast of 12-20+ small dishes served with rice — satay, rendang, gado gado, sambal, tempeh, and more. Amsterdam\'s most unique dining experience, born from the colonial era. Try Kantjil & de Tijger or Blauw.',
        tag: 'Iconic',
      },
      {
        name: 'Nasi Goreng',
        image: '/images/cuisine/nasigoreng.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'de-pijp',
        price: '10-16 EUR / $11-17 USD',
        description: 'Indonesian fried rice with chicken, egg, vegetables, and sweet soy sauce (kecap manis), topped with a fried egg and kerupuk (prawn crackers). Available at Indonesian restaurants and takeaways across the city.',
        tag: 'Must-Try',
      },
      {
        name: 'Satay (Saté)',
        image: '/images/cuisine/satay.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'de-pijp',
        price: '8-14 EUR / $9-15 USD',
        description: 'Grilled meat skewers (usually chicken or pork) with rich peanut sauce. A staple of Indonesian restaurants and street food stalls. Often part of a rijsttafel but excellent on its own with sambal.',
        tag: 'Must-Try',
      },
      {
        name: 'Roti',
        image: '/images/cuisine/roti.jpg',
        destination: 'De Pijp & Centrum',
        slug: 'de-pijp',
        price: '8-14 EUR / $9-15 USD',
        description: 'Surinamese flatbread served with curried chicken or lamb, potatoes, egg, and long beans. Amsterdam\'s beloved Surinamese street food — Roopram Roti on Eerste van der Helststraat in De Pijp is legendary.',
        tag: 'Iconic',
      },
      {
        name: 'Bami Goreng',
        image: '/images/cuisine/bamigoreng.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '10-16 EUR / $11-17 USD',
        description: 'Indonesian stir-fried noodles with vegetables, chicken or shrimp, and sweet soy sauce. The noodle equivalent of nasi goreng — comfort food that Amsterdam has made its own.',
      },
      {
        name: 'Broodje Pom',
        image: '/images/cuisine/brodjepom.jpg',
        destination: 'De Pijp & Centrum',
        slug: 'de-pijp',
        price: '5-8 EUR / $5-9 USD',
        description: 'A Surinamese casserole of tayer root and chicken on a soft roll — one of Amsterdam\'s most beloved fusion sandwiches. Found at Surinamese takeaways across the city. Rich, savory, and uniquely Amsterdam.',
        tag: 'Heritage',
      },
    ],
  },
  {
    region: 'Cheese & Dairy',
    tagline: 'The Netherlands is a cheese powerhouse — Gouda, Edam, and artisan varieties you won\'t find anywhere else in the world',
    gradient: 'linear-gradient(135deg, #1A2332 0%, #6A1B9A 50%, #D4A853 100%)',
    dishes: [
      {
        name: 'Aged Gouda',
        image: '/images/cuisine/gouda.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '4-10 EUR / $4-11 USD per wedge',
        description: 'Dutch Gouda ranges from young and mild to aged (overjarig) with deep caramel and crystalline crunch. Visit a kaaswinkel (cheese shop) and sample the full range. Reypenaer Cheese Tasting Room offers excellent guided tastings.',
        tag: 'Iconic',
      },
      {
        name: 'Edam',
        image: '/images/cuisine/edam.jpg',
        destination: 'Day trip from Amsterdam',
        slug: 'zaanse-schans',
        price: '3-8 EUR / $3-9 USD per wedge',
        description: 'The famous round cheese with a red wax coating. Milder and creamier than Gouda. The town of Edam is a short day trip from Amsterdam — visit the Edam cheese market in summer for the authentic experience.',
        tag: 'Heritage',
      },
      {
        name: 'Kaastosti',
        image: '/images/cuisine/kaastosti.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'jordaan',
        price: '4-8 EUR / $4-9 USD',
        description: 'A classic Dutch grilled cheese sandwich — simple, golden, and oozing with melted Gouda. Served at brown cafes, lunch spots, and cafeterias across the city. Often with a bowl of tomato soup alongside.',
        tag: 'Must-Try',
      },
      {
        name: 'Vla',
        image: '/images/cuisine/vla.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '2-3 EUR / $2-3 USD',
        description: 'Dutch custard dessert available in vanilla, chocolate, or caramel flavors. Found in every supermarket and served at traditional restaurants. A simple, creamy dessert that\'s quintessentially Dutch.',
      },
      {
        name: 'Kaassoufflé',
        image: '/images/cuisine/kaassouffle.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '2-4 EUR / $2-4 USD',
        description: 'A deep-fried puff pastry filled with melted Gouda cheese. Another FEBO vending-machine classic. Crispy outside, molten cheese inside — the perfect late-night snack after exploring Amsterdam\'s nightlife.',
        tag: 'Must-Try',
      },
      {
        name: 'Cheese Platters',
        image: '/images/cuisine/cheeseplate.jpg',
        destination: 'Jordaan',
        slug: 'jordaan',
        price: '12-20 EUR / $13-22 USD',
        description: 'A borrelplank (drinks platter) with a selection of Dutch cheeses, mustard, bread, and pickles — the essential accompaniment to an afternoon beer in a Jordaan brown cafe. Often includes bitterballen and olives.',
        tag: 'Heritage',
      },
    ],
  },
  {
    region: 'Sweet Treats & Drinks',
    tagline: 'From jenever to appeltaart, Amsterdam satisfies every sweet tooth and thirst — old-world traditions meet modern cafe culture',
    gradient: 'linear-gradient(135deg, #E65100 0%, #FF9800 100%)',
    dishes: [
      {
        name: 'Appeltaart',
        image: '/images/cuisine/appeltaart.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'jordaan',
        price: '4-7 EUR / $4-8 USD per slice',
        description: 'Deep-dish Dutch apple pie loaded with cinnamon-spiced apples in a buttery crust, served warm with whipped cream (slagroom). Winkel 43 in the Jordaan serves what many consider the best appeltaart in Amsterdam.',
        tag: 'Iconic',
      },
      {
        name: 'Jenever',
        image: '/images/cuisine/jenever.jpg',
        destination: 'Centrum & Jordaan',
        slug: 'jordaan',
        price: '4-8 EUR / $4-9 USD per glass',
        description: 'The Dutch ancestor of gin — a juniper-flavored spirit sipped from a tulip-shaped glass filled to the brim. Visit a proeflokaal (tasting house) like Wynand Fockink or De Drie Fleschjes for the authentic experience.',
        tag: 'Must-Try',
      },
      {
        name: 'Oliebollen',
        image: '/images/cuisine/oliebollen.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '2-4 EUR / $2-4 USD each',
        description: 'Deep-fried dough balls dusted with powdered sugar — Amsterdam\'s traditional New Year\'s Eve treat. Seasonal stalls pop up across the city from November onward. Often filled with raisins, apple, or custard.',
        tag: 'Heritage',
      },
      {
        name: 'Dutch Beer',
        image: '/images/cuisine/dutchbeer.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '4-7 EUR / $4-8 USD per glass',
        description: 'From Heineken and Amstel to craft breweries like Brouwerij \'t IJ (in a windmill!) and Oedipus. Amsterdam\'s beer scene ranges from classic pilsners to experimental craft ales. The Jordaan and De Pijp have the best craft beer bars.',
        tag: 'Must-Try',
      },
      {
        name: 'Tompoes (Tompouce)',
        image: '/images/cuisine/tompoes.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'centrum',
        price: '3-5 EUR / $3-5 USD',
        description: 'A puff pastry slice with vanilla custard filling and bright pink or orange icing. The iconic Dutch pastry — turns orange for King\'s Day. Found at every bakery across the city.',
        tag: 'Heritage',
      },
      {
        name: 'Dutch Coffee',
        image: '/images/cuisine/dutchcoffee.jpg',
        destination: 'Throughout Amsterdam',
        slug: 'jordaan',
        price: '3-5 EUR / $3-5 USD',
        description: 'Amsterdam\'s specialty coffee scene is world-class. From traditional koffie verkeerd (cafe latte) to third-wave pour-overs at Lot Sixty One, Scandinavian Embassy, or Coffee District. Always served with a small cookie on the side.',
      },
    ],
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="menu-hero">
    <video class="menu-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/cuisine-hero.mp4" type="video/mp4" />
    </video>
    <div class="menu-hero-gradient"></div>
    <div class="menu-hero-noise"></div>
    <div class="menu-hero-content">
      <h1 class="menu-hero-title">The Dutch Menu</h1>
      <p class="menu-hero-subtitle">Crispy bitterballen in a brown cafe, fresh stroopwafels at Albert Cuyp Market, rijsttafel feasts in the Jordaan — eat your way across Amsterdam and discover the dishes that define each neighborhood.</p>
      <div class="menu-hero-meta">
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Dishes</span>
          <span class="menu-hero-meta-value">32</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Regions</span>
          <span class="menu-hero-meta-value">4</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Destinations</span>
          <span class="menu-hero-meta-value">15</span>
        </div>
      </div>
    </div>
    <div class="menu-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="menu-personal reveal">
    <div class="container-content">
      <blockquote class="menu-personal-quote">
        <p>Amsterdam food surprised us completely. Our first trip, we stuck to tourist restaurants near Dam Square and thought Dutch food was just cheese and fries. Then a local friend took us to a tiny brown cafe in the Jordaan where the bartender served fresh bitterballen with sharp mustard, aged Gouda that crumbled with caramel sweetness, and a tulip glass of jenever. That was the moment. Now the food is half the reason we keep coming back — from Indonesian rijsttafel feasts to Surinamese roti in De Pijp to fresh herring from a canal-side cart.</p>
        <cite>— Scott &amp; Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- Menu Intro -->
  <section class="menu-intro reveal">
    <div class="container-content">
      <div class="menu-intro-card">
        <p class="menu-intro-text">Think of this as your tasting menu for Amsterdam. We've organized the city's essential dishes by category — <strong>Classic Dutch</strong>, <strong>Indonesian & Surinamese</strong>, <strong>Cheese & Dairy</strong>, and <strong>Sweet Treats & Drinks</strong>. Click any dish to explore the neighborhood where it's famous.</p>
        <div class="menu-intro-legend">
          <span class="menu-tag menu-tag--heritage">Heritage</span>
          <span class="menu-tag menu-tag--musttry">Must-Try</span>
          <span class="menu-tag menu-tag--iconic">Iconic</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Sections by Region -->
  {menu.map((section) => (
    <section class="menu-region reveal">
      <div class="container-content">
        <div class="menu-region-header" style={`background: ${section.gradient};`}>
          <div class="menu-region-header-inner">
            <h2 class="menu-region-name">{section.region}</h2>
            <p class="menu-region-tagline">{section.tagline}</p>
            <span class="menu-region-count">{section.dishes.length} dishes</span>
          </div>
          <div class="menu-region-ornament">&#9733;</div>
        </div>

        <div class="menu-dish-grid">
          {section.dishes.map((dish) => (
            <a href={`/destinations/${dish.slug}/`} class="menu-dish-card">
              <div class="menu-dish-media" style={`background: ${section.gradient};`}>
                {dish.image && (
                  <img src={dish.image} alt={`${dish.name} — ${dish.destination}`} class="menu-dish-img" loading="lazy" />
                )}
                {dish.tag && (
                  <span class={`menu-tag menu-tag--${dish.tag.toLowerCase().replace(/[^a-z]/g, '')}`}>{dish.tag}</span>
                )}
              </div>
              <div class="menu-dish-body">
                <div class="menu-dish-top">
                  <h3 class="menu-dish-name">{dish.name}</h3>
                  <span class="menu-dish-price">{dish.price}</span>
                </div>
                <p class="menu-dish-destination">{dish.destination}</p>
                <p class="menu-dish-desc">{dish.description}</p>
                <span class="menu-dish-cta">Explore {dish.destination} &rarr;</span>
              </div>
              <div class="menu-dish-overlay">
                <p class="menu-dish-overlay-desc">{dish.description}</p>
                <span class="menu-dish-overlay-cta">Explore {dish.destination} &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="menu-cta-section reveal">
    <div class="container-content">
      <div class="menu-cta-card">
        <h2 class="menu-cta-heading">Plan Your Food Trip</h2>
        <p class="menu-cta-text">Tell our AI planner which dishes you want to try and it will build a region-by-region itinerary — with the best restaurants, markets, and street food stops.</p>
        <a href="/plan/" class="menu-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What is Amsterdam's most famous dish?", answer: "Bitterballen are Amsterdam's most iconic snack — crispy fried meatball croquettes served with mustard at every brown cafe. Stroopwafels are the most internationally recognized Dutch treat. But the real discovery is Amsterdam's Indonesian rijsttafel — a colonial-era feast of 12-20+ small dishes that's unlike anything else in Europe." },
    { question: "Is Dutch food just cheese and fries?", answer: "Not at all — Amsterdam has one of the most diverse food scenes in Europe. Beyond classic Dutch dishes like stamppot and kroket, the city has world-class Indonesian restaurants (rijsttafel), Surinamese street food (roti, broodje pom), Turkish bakeries, Moroccan tagine, and a thriving modern cafe culture. Amsterdam's colonial history created fusion cuisines you won't find anywhere else." },
    { question: "What are the must-try street foods in Amsterdam?", answer: "Stroopwafels fresh from a market stall (2-4 EUR), bitterballen or kroket from FEBO's vending wall (2-4 EUR), kibbeling (fried fish chunks, 5-8 EUR), raw herring from a haringkar (4-6 EUR), poffertjes (mini pancakes, 4-7 EUR), and Surinamese roti (8-14 EUR). Amsterdam street food is exceptional, affordable, and found on every corner." },
    { question: "How much does a meal cost in Amsterdam?", answer: "Street food: 3-8 EUR. A main at a casual cafe or brown cafe: 12-20 EUR. A rijsttafel dinner for two with drinks: 60-100 EUR. Fine dining: 60-120+ EUR per person. A daily food budget of 30-60 EUR covers three meals comfortably, including coffee and a beer. Amsterdam is pricier than Southern Europe but comparable to other Northern European capitals." },
    { question: "What should I know about dining etiquette in Amsterdam?", answer: "The Dutch eat dinner early compared to Southern Europe — typically 6-8 PM. Lunch is often a quick sandwich (broodje). Tipping is not mandatory but rounding up or leaving 5-10% for good service is appreciated. The concept of borrel (drinks and snacks, usually around 5 PM on Fridays) is central to Dutch social life. Tap water is free and safe to drink — just ask for kraanwater." },
    { question: "What is the most famous Dutch dessert?", answer: "Stroopwafels are Amsterdam's most famous sweet treat — caramel-filled waffle cookies best eaten warm. Appeltaart (Dutch apple pie with whipped cream) is served at every cafe. Oliebollen (fried dough balls) are the traditional New Year's treat. Poffertjes (mini buckwheat pancakes) and tompoes (custard pastry slices) round out Amsterdam's beloved dessert tradition." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Dutch Food Guide"
      description="A neighborhood-by-neighborhood PDF guide to Amsterdam cuisine — with the best restaurants, street food stalls, and dishes you can't miss."
      bullets={[
        'All top dishes with where to find the best version in Amsterdam',
        'Price guide — from 2 EUR street food to 45 EUR rijsttafel feasts',
        'Dining etiquette tips and borrel culture explained',
        'Neighborhood food map — Jordaan, De Pijp, Centrum, and beyond',
      ]}
      guideTag="pillar-cuisine"
    />
  </div>

  <!-- Cross-links -->
  <section class="menu-crosslinks reveal">
    <div class="container-content">
      <h3 class="menu-crosslinks-heading">Explore More</h3>
      <div class="menu-crosslinks-grid">
        <a href="/festivals/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127914;</span>
          <span class="menu-crosslink-label">Festival Calendar</span>
          <span class="menu-crosslink-desc">Amsterdam's best festivals and events, month by month</span>
        </a>
        <a href="/practical/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127890;</span>
          <span class="menu-crosslink-label">Travel Tips</span>
          <span class="menu-crosslink-desc">Visa, money, transport, and cultural etiquette</span>
        </a>
        <a href="/destinations/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127965;</span>
          <span class="menu-crosslink-label">All Destinations</span>
          <span class="menu-crosslink-desc">Every city and region we've explored with honest reviews</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  /* ================================================================
     HERO — Warm, food-inspired gradient
     ================================================================ */
  .menu-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem var(--space-6) 60px;
    overflow: hidden;
  }

  .menu-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .menu-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%);
  }

  .menu-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .menu-hero-content {
    position: relative;
    z-index: 3;
    max-width: 720px;
  }

  .menu-hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 var(--space-3);
  }

  .menu-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 var(--space-5);
